APP_ENV=development
JWT_SECRET=local-dev-secret-at-least-32-characters-long
DB_HOST=localhost
DB_PORT=5432
DB_USER=buygo
DB_PASSWORD=local-dev-password
DB_NAME=buygo
DB_SSLMODE=disable
CORS_ORIGIN=http://localhost:4200
# Set to "true" to enable Firebase mock mode (development only, never in production)
ENABLE_MOCK_AUTH=true
